sages:\n        if getattr(msg, \"type\", None) == \"ai\":\n            content = getattr(msg, \"content\", \"\")\n            if isinstance(content, str):\n                return content[:200]  # First 200 chars for title\n    return None\n```\n\n- [ ] **Step 4: Commit**\n\n```bash\ngit add src/agent_tui/domain/protocol.py src/agent_tui/services/deep_agents/event_translator.py\ngit commit -m \"feat: add TITLE_REQUESTED event type and tracking\"\n```\n\n---\n\n## Chunk 2: Title Generator\n\n**Files:**\n- Create: `src/agent_tui/services/deep_agents/title.py`\n- Tests: `tests/services/deep_agents/test_title.py` (create directory if needed)\n\n- [ ] **Step 1: Write failing test**\n\n```python\n# tests/services/deep_agents/test_title.py\nimport pytest\nfrom agent_tui.services.deep_agents.title import TitleGenerator\n\n\n@pytest.fixture\ndef title_generator():\n    return TitleGenerator()\n\n\n@pytest.mark.asyncio\nasync def test_generate_title_returns_string(title_generator):\n    result = await title_generator.generate_title(\n        user_message=\"Create FastAPI endpoint in main.py, use uv as package manager\",\n        assistant_response=\"I'll create a FastAPI endpoint for you. First, I'll set up the project...\"\n    )\n    assert isinstance(result, str)\n    assert len(result) <= 50\n\n\n@pytest.mark.asyncio\nasync def test_generate_title_strips_whitespace(title_generator):\n    result = await title_generator.generate_title(\n        user_message=\"How do I fix a bug?\",\n        assistant_response=\"Here are the steps...\"\n    )\n    assert result == result.strip()\n\n\n@pytest.mark.asyncio\nasync def test_generate_title_fallback_on_empty_input(title_generator):\n    result = await title_generator.generate_title(\"\", \"\")\n    assert result == \"Untitled Chat\"\n```\n\nRun: `pytest tests/services/deep_agents/test_title.py -v`\nExpected: FAIL ‚Äî module doesn't exist\n\n- [ ] **Step 2: Create TitleGenerator**\n\n```python\n\"\"\"TitleGenerator - generates chat