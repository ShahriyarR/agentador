n        return self._model\n\n    async def generate_title(\n        self,\n        user_message: str,\n        assistant_response: str,\n    ) -> str:\n        \"\"\"Generate a short title from conversation context.\n\n        Args:\n            user_message: First user message.\n            assistant_response: First assistant response.\n\n        Returns:\n            A short title (max 50 chars) for the conversation.\n        \"\"\"\n        if not user_message and not assistant_response:\n            return \"Untitled Chat\"\n\n        prompt = self.TITLE_PROMPT.format(\n            user_message=user_message,\n            assistant_response=assistant_response\n        )\n\n        try:\n            model = self._get_model()\n            response = await model.ainvoke(prompt)\n            title = response.content if hasattr(response, \"content\") else str(response)\n            title = title.strip()[:50]\n            return title or \"Untitled Chat\"\n        except Exception:\n            logger.exception(\"Title generation failed\")\n            return \"Untitled Chat\"\n```\n\nRun: `pytest tests/services/deep_agents/test_title.py -v`\nExpected: PASS\n\n- [ ] **Step 3: Add `update_chat_title` method to SessionStore**\n\nAdd to `SessionStore` class in `src/agent_tui/services/sessions.py`:\n\n```python\nasync def update_chat_title(self, chat_id: str, title: str) -> dict[str, Any] | None:\n    \"\"\"Update a chat's title.\n\n    Args:\n        chat_id: The chat ID to update.\n        title: New title for the chat.\n\n    Returns:\n        Updated chat dictionary or None if not found.\n    \"\"\"\n    aiosqlite_mod = _get_aiosqlite()\n\n    async with aiosqlite_mod.connect(self.db_path) as db:\n        db.row_factory = aiosqlite_mod.Row\n\n        # Check if chat exists\n        async with db.execute(\n            \"SELECT * FROM chat_sessions WHERE id = ?\",\n            (chat_id,)\n        ) as cursor:\n            row = await cursor.fetchone()\n            if not row:\n                return None\n\n        # Update title\n        await db.execute(\n            \"UPDATE chat_sessions SET title = ?, updated_at = ? WHERE id = ?\",\n            (title, datetime.now().isoformat(), chat_id)\n        )\n        await db.commit()\n\n        # Return updated chat\n        async with db.execute(\n            \"SELECT * FROM chat_sessions WHERE id = ?\",\n            (chat_id,)\n        ) as cursor:\n            row = await cursor.fetchone()\n            return dict(row) if row else None\n```\n\n- [ ] **Step 4: Commit**\n\n```bash\ngit add src/agent_tui/services/deep_agents/title.py src/agent_tui/services/deep_agents/events.py src/agent_tui/services/sessions.py tests/services/deep_agents/test_title.py\ngit commit -m \"feat: add TitleGenerator for async chat title generation\"\n```\n\n---\n\n## Chunk 3: Wire TITLE_REQUESTED into EventTranslator\n\n**Files:**\n- Modify: `src/agent_tui/services/deep_agents/event_translator.py`\n\n- [ ] **Step 1: Add TITLE_REQUESTED to AgentEvent/EventType**\n\nModify `src/agent_tui/domain/protocol.py` to add new event type:\n\n```python\n# In EventType enum:\nTITLE_REQUESTED = \"title_requested\"\n\n# In AgentEvent dataclass attributes:\nuser_message: str = \"\"\nassistant_response: str = \"\"\nthread_id: str = \"\"\n```\n\n- [ ] **Step 2: Modify EventTranslator to detect first assistant complete**\n\nUpdate `event_translator.py` to track state and emit `TITLE_REQUESTED`:\n\n```python\nclass EventTranslator:\n    def __init__(self):\n        self._firstAssistantComplete = False\n        self._firstUserMessage = \"\"\n        self._firstAssistantResponse = \"\"\n\n    def translate(self, event: dict[str, Any]) -> Iterator[AgentEvent]:\n        # ... existing code ...\n\n    def _handle_chat_model_stream(self, data, event):\n        # Existing MESSAGE_CHUNK handling...\n        for agent_event in translated:\n            yield agent_event\n\n        # Track first assistant response\n        # After yielding MESSAGE_CHUNK for first assistant, check if chain is ending\n```\n\nActually, simpler approach ‚Äî emit `TITLE_REQUESTED` on `on_chain_end` when we have first user+assistant:\n\n```python\ndef translate(self, event):\n    # ... existing handling first ...\n\n    if event_type == \"on_chain_end\":\n        yield from self._handle_chain_end(...)\n        # Check if first assistant just completed\n        if self._firstAssistantResponse and not self._firstAssistantComplete:\n            self._firstAssistantComplete = True\n            yield AgentEvent(\n                type=EventType.TITLE_REQUESTED,\n                user_message=self._firstUserMessage,\n                assistant_response=self._firstAssistantResponse,\n                thread_id=\"\",  # Set by adapter\n            )\n```\n\nNeed to track `user_message` too. Update `_handle_chain_stream` to detect first human message.\n\n- [ ] **Step 3: Commit**\n\n```bash\ngit add src/agent_tui/services/deep_agents/event_translator.py src/agent_tui/domain/protocol.py\ngit commit -m \"feat: emit TITLE_REQUESTED after first assistant response\"\n```\n\n---\n\n## Chunk 4: WebAdapter handles TITLE_REQUESTED\n\n**Files:**\n- Modify: `src/agent_tui/services/web_adapter.py`\n\n- [ ] **Step 1: Add WebSocket title_updated event handler**\n\nAdd to `WebAdapter._dispatch`:\n\n```python\ncase EventType.TITLE_REQUESTED:\n    # Spawn background title generation (non-blocking)\n    asyncio.create_task(self._generate_title(\n        event.user_message,\n        event.assistant_response,\n        event.thread_id,\n    ))\n```\n\nAdd new method:\n\n```python\nasync def _generate_title(\n    self,\n    user_message: str,\n    assistant_response: str,\n    thread_id: str,\n) -> None:\n    \"\"\"Generate title in background and update store.\"\"\"\n    from agent_tui.services.deep_agents.title import TitleGenerator\n    from agent_tui.web.routes.api import get_session_store\n\n    try:\n        generator = TitleGenerator()\n        title = await generator.generate_title(\n            user_message=user_message,\n            assistant_response=assistant_response,\n        )\n\n        store = get_session_store()\n        await store.update_chat_title(thread_id, title)\n\n        # Emit title_updated to WebSocket clients\n        await self.websocket.send_json({\n            \"type\": \"title_updated\",\n            \"chat_id\": thread_id,\n            \"title\": title,\n        })\n    except Exception:\n        logger.exception(\"Background title generation failed\")\n```\n\n- [ ] **Step 2: Commit**\n\n```bash\ngit add src/agent_tui/services/web_adapter.py\ngit commit -m \"feat: handle TITLE_REQUESTED with background title generation\"\n```\n\n---\n\n## Chunk 5: UI Updates\n\n**Files:**\n- Modify: `src/agent_tui/web/templates/chat.html`\n\n- [ ] **Step 1: Add spinner to chat title in sidebar**\n\nIn sidebar chat list item:\n```html\n<!-- During title generation -->\n<span x-show=\"chat.generating_title\" class=\"title-spinner\">‚ü≥</span>\n```\n\n- [ ] **Step 2: Handle title_updated WebSocket event**\n\n```javascript\n// In Alpine.js websocket handler:\ncase \"title_updated\":\n    const chatId = event.chat_id;\n    const title = event.title;\n    // Update chat in sidebar\n    const chat = chats.find(c => c.id === chatId);\n    if (chat) {\n        chat.title = title;\n        chat.generating_title = false;\n    }\n    break;\n```\n\n- [ ] **Step 3: Commit**\n\n```bash\ngit add src/agent_tui/web/templates/chat.html\ngit commit -m \"feat: handle title_updated in UI\"\n```\n\n---\n\n## Verification\n\nRun: `pytest tests/ -v --tb=short`\n\nExpected: All tests pass including new title generator tests.\n",
