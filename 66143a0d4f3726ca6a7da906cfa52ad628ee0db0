ers.\n\n        Args:\n            servers: Dictionary of server_name -> server_info with 'connected' key.\n        \"\"\"\n        try:\n            servers_container = self.query_one(\"#mcp-servers-list\", Vertical)\n        except Exception:\n            return\n\n        servers_container.remove_children()\n\n        if not servers:\n            servers_container.mount(Label(\"No servers\", classes=\"info-empty\"))\n            return\n\n        for server_name, server_info in servers.items():\n            is_connected = server_info.get(\"connected\", False)\n            status_icon = \"●\" if is_connected else \"○\"\n            status_class = \"info-mcp-connected\" if is_connected else \"info-mcp-disconnected\"\n            servers_container.mount(\n                Label(\n                    f\"{status_icon} {server_name}\",\n                    classes=f\"info-mcp-server {status_class}\",\n                )\n            )\n\n    def add_modified_file(self, filepath: str, change_type: str) -> None:\n        \"\"\"Add a modified file to the list.\n\n        Args:\n            filepath: Path to the modified file.\n            change_type: Type of change - 'created', 'modified', or 'touched'.\n        \"\"\"\n        try:\n            files_container = self.query_one(\"#modified-files-list\", Vertical)\n        except Exception:\n            return\n\n        if change_type == \"created\":\n            icon = \"+\"\n            file_class = \"info-file-created\"\n        elif change_type == \"modified\":\n            icon = \"~\"\n            file_class = \"info-file-modified\"\n        else:\n            icon = \"•\"\n            file_class = \"info-file-touched\"\n\n        files_container.mount(\n            Label(\n                f\"{icon} {filepath}\",\n                classes=f\"info-file {file_class}\",\n            )\n        )\n\n    def clear_modified_files(self) -> None:\n        \"\"\"Clear all modified files from the list.\"\"\"\n        try:\n    