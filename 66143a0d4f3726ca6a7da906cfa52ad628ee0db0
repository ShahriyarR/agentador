            "content": "\"\"\"Tests for InfoPanel widget.\"\"\"\n\nfrom __future__ import annotations\n\nfrom typing import Any\nfrom unittest.mock import MagicMock, patch\n\nimport pytest\n\nfrom agent_tui.entrypoints.widgets.info_panel import InfoPanel\n\n\nclass TestInfoPanelBasic:\n    \"\"\"Basic tests for InfoPanel widget initialization.\"\"\"\n\n    def test_init_default_values(self):\n        \"\"\"InfoPanel should initialize with default values.\"\"\"\n        panel = InfoPanel()\n\n        assert panel.tokens == 0\n        assert panel.context_limit == 0\n        assert panel.approximate is False\n\n    def test_init_with_kwargs(self):\n        \"\"\"InfoPanel should accept kwargs.\"\"\"\n        panel = InfoPanel(id=\"test-panel\")\n\n        assert panel.id == \"test-panel\"\n\n\nclass TestInfoPanelCompose:\n    \"\"\"Tests for InfoPanel compose and UI structure.\"\"\"\n\n    def test_compose_returns_widgets(self):\n        \"\"\"Panel compose should yield widgets.\"\"\"\n        panel = InfoPanel()\n\n        result = panel.compose()\n        assert result is not None\n\n    def test_panel_has_expected_structure(self):\n        \"\"\"Panel should have the expected CSS class structure.\"\"\"\n        panel = InfoPanel()\n\n        assert \"info-header\" in panel.DEFAULT_CSS\n        assert \"info-context\" in panel.DEFAULT_CSS\n        assert \"info-mcp-list\" in panel.DEFAULT_CSS\n        assert \"info-files-list\" in panel.DEFAULT_CSS\n        assert \"info-footer\" in panel.DEFAULT_CSS\n\n\nclass TestInfoPanelTokens:\n    \"\"\"Tests for InfoPanel token display functionality.\"\"\"\n\n    def test_set_tokens_updates_values(self):\n        \"\"\"set_tokens should update reactive values.\"\"\"\n        panel = InfoPanel()\n\n        panel.set_tokens(5000, approximate=False, context_limit=100000)\n\n        assert panel.tokens == 5000\n        assert panel.approximate is False\n        assert panel.context_limit == 100000\n\n    def test_set_tokens_with_approximate(self):\n        \"\"\"set_tokens should handle approximate flag.\"\"\"\n        panel = InfoPanel()\n\n        panel.set_tokens(5000, approximate=True, context_limit=100000)\n\n        assert panel.tokens == 5000\n        assert panel.approximate is True\n\n    def test_render_tokens_handles_zero(self):\n        \"\"\"_render_tokens should handle zero tokens.\"\"\"\n        panel = InfoPanel()\n\n        with patch.object(panel, \"query_one\") as mock_query:\n            mock_label = MagicMock()\n            mock_progress = MagicMock()\n            mock_query.side_effect = [mock_label, mock_progress] if False else Exception()\n\n            panel._render_tokens()\n\n    def test_render_tokens_with_count(self):\n        \"\"\"_render_tokens should format token count correctly.\"\"\"\n        panel = InfoPanel()\n        panel.tokens = 8200\n        panel.approximate = False\n        panel.context_limit = 100000\n\n        with patch.object(panel, \"query_one\") as mock_query:\n            mock_label = MagicMock()\n            mock_progress = MagicMock()\n            mock_query.side_effect = [mock_label, mock_progress]\n\n            panel._render_tokens()\n\n            mock_label.update.assert_called()\n            call_args = mock_label.update.call_args[0][0]\n            assert \"8.2K\" in call_args\n\n\nclass TestInfoPanelMCPServers:\n    \"\"\"Tests for InfoPanel MCP server display.\"\"\"\n\n    def test_set_mcp_servers_empty(self):\n        \"\"\"set_mcp_servers should show empty message for no servers.\"\"\"\n        panel = InfoPanel()\n\n        with patch.object(panel, \"query_one\") as mock_query:\n            mock_container = MagicMock()\n            mock_query.return_value = mock_container\n\n            panel.set_mcp_servers({})\n\n            mock_container.remove_children.assert_called_once()\n            mock_container.mount.assert_called_once()\n            call_args = mock_container.mount.call_args\n            label = call_args[0][0]\n            assert \"info-empty\" in str(label.classes)\n\n    def test_set_mcp_servers_connected(self):\n        \"\"\"set_mcp_servers should render connected server correctly.\"\"\"\n        panel = InfoPanel()\n\n        with patch.object(panel, \"query_one\") as mock_query:\n            mock_container = MagicMock()\n            mock_query.return_value = mock_container\n\n            panel.set_mcp_servers({\"server1\": {\"connected\": True}})\n\n            mock_container.remove_children.assert_called_once()\n            mock_container.mount.assert_called_once()\n            call_args = mock_container.mount.call_args\n            label = call_args[0][0]\n            assert \"●\" in str(label.renderable)\n            assert \"info-mcp-connected\" in str(label.classes)\n\n    def test_set_mcp_servers_disconnected(self):\n        \"\"\"set_mcp_servers should render disconnected server correctly.\"\"\"\n        panel = InfoPanel()\n\n        with patch.object(panel, \"query_one\") as mock_query:\n            mock_container = MagicMock()\n            mock_query.return_value = mock_container\n\n            panel.set_mcp_servers({\"server1\": {\"connected\": False}})\n\n            mock_container.remove_children.assert_called_once()\n            mock_container.mount.assert_called_once()\n            call_args = mock_container.mount.call_args\n            label = call_args[0][0]\n            assert \"○\" in str(label.renderable)\n            assert \"info-mcp-disconnected\" in str(label.classes)\n\n\nclass TestInfoPanelModifiedFiles:\n    \"\"\"Tests for InfoPanel modified files display.\"\"\"\n\n    def test_add_modified_file_created(self):\n        \"\"\"add_modified_file should show + for created files.\"\"\"\n        panel = InfoPanel()\n\n        with patch.object(panel, \"query_one\") as mock_query:\n            mock_container = MagicMock()\n            mock_query.return_value = mock_container\n\n            panel.add_modified_file(\"new_file.py\", \"created\")\n\n            mock_container.mount.assert_called_once()\n            call_args = mock_container.mount.call_args\n            label = call_args[0][0]\n            assert \"+\" in str(label.renderable)\n            assert \"info-file-created\" in str(label.classes)\n\n    def test_add_modified_file_modified(self):\n        \"\"\"add_modified_file should show ~ for modified files.\"\"\"\n        panel = InfoPanel()\n\n        with patch.object(panel, \"query_one\") as mock_query:\n            mock_container = MagicMock()\n            mock_query.return_value = mock_container\n\n            panel.add_modified_file(\"existing_file.py\", \"modified\")\n\n            mock_container.mount.assert_called_once()\n            call_args = mock_container.mount.call_args\n            label = call_args[0][0]\n            assert \"~\" in str(label.renderable)\n            assert \"info-file-modified\" in str(label.classes)\n\n    def test_add_modified_file_touched(self):\n        \"\"\"add_modified_file should show • for touched files.\"\"\"\n        panel = InfoPanel()\n\n        with patch.object(panel, \"query_one\") as mock_query:\n            mock_container = MagicMock()\n            mock_query.return_value = mock_container\n\n            panel.add_modified_file(\"touched_file.py\", \"touched\")\n\n            mock_container.mount.assert_called_once()\n            call_args = mock_container.mount.call_args\n            label = call_args[0][0]\n            assert \"•\" in str(label.renderable)\n            assert \"info-file-touched\" in str(label.classes)\n\n    def test_clear_modified_files(self):\n        \"\"\"clear_modified_files should remove all files.\"\"\"\n        panel = InfoPanel()\n\n        with patch.object(panel, \"query_one\") as mock_query:\n            mock_container = MagicMock()\n            mock_query.return_value = mock_container\n\n            panel.clear_modified_files()\n\n            mock_container.remove_children.assert_called_once()\n\n\nclass TestInfoPanelProjectInfo:\n    \"\"\"Tests for InfoPanel project info display.\"\"\"\n\n    def test_set_project_info_full(self):\n        \"\"\"set_project_info should format project info correctly.\"\"\"\n        panel = InfoPanel()\n\n        with patch.object(panel, \"query_one\") as mock_query:\n            mock_label = MagicMock()\n            mock_query.return_value = mock_label\n\n            panel.set_project_info(\"/home/user/project\", \"main\", \"agent-tui\", \"1.0.0\")\n\n            mock_label.update.assert_called_once()\n            call_args = mock_label.update.call_args[0][0]\n            assert \"agent-tui@1.0.0\" in call_args\n\n    def test_set_project_info_abbreviates_home(self):\n        \"\"\"set_project_info should abbreviate home directory.\"\"\"\n        panel = InfoPanel()\n\n        with patch.object(panel, \"query_one\") as mock_query:\n            mock_label = MagicMock()\n            mock_query.return_value = mock_label\n\n            panel.set_project_info(\"/home/user/project\", \"feature\", \"cli\", \"2.0\")\n\n            mock_label.update.assert_called_once()\n            call_args = mock_label.update.call_args[0][0]\n            assert \"~/\" in call_args\n            assert \"/home/\" not in call_args\n\n\nclass TestInfoPanelCSS:\n    \"\"\"Tests for InfoPanel CSS classes.\"\"\"\n\n    def test_default_css_is_defined(self):\n        \"\"\"InfoPanel should have DEFAULT_CSS defined.\"\"\"\n        assert InfoPanel.DEFAULT_CSS is not None\n        assert len(InfoPanel.DEFAULT_CSS) > 0\n\n    def test_css_contains_expected_classes(self):\n        \"\"\"CSS should contain expected class definitions.\"\"\"\n        css = InfoPanel.DEFAULT_CSS\n\n        expected_classes = [\n            \"info-section\",\n            \"info-header\",\n            \"info-context\",\n            \"info-token-row\",\n            \"info-token-label\",\n            \"info-token-value\",\n            \"info-progress-container\",\n            \"info-progress-bar\",\n