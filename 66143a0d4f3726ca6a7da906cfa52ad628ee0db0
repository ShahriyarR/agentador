            "content": "# Right Sidebar Panel Implementation Plan\n\n> **For agentic workers:** REQUIRED: Use superpowers:subagent-driven-development (if subagents available) or superpowers:executing-plans to implement this plan. Steps use checkbox (`- [ ]`) syntax for tracking.\n\n**Goal:** Add a persistent right sidebar panel displaying context tokens, MCP servers, modified files, and project info.\n\n**Architecture:** New `InfoPanel` widget following existing patterns from `MCPPanel`. Toggles via Ctrl+M, auto-hides on narrow terminals. File tracking via tool call events.\n\n**Tech Stack:** Textual widgets, existing session_stats, MCPToolManager\n\n---\n\n## Chunk 1: Create InfoPanel Widget\n\n**Files:**\n- Create: `src/agent_tui/entrypoints/widgets/info_panel.py`\n- Modify: `src/agent_tui/entrypoints/app.tcss:365-370`\n- Test: `tests/entrypoints/widgets/test_info_panel.py` (create)\n\n- [ ] **Step 1: Create info_panel.py**\n\n```python\n\"\"\"Right sidebar info panel widget.\"\"\"\n\nfrom __future__ import annotations\n\nfrom typing import TYPE_CHECKING, Any\n\nfrom textual.containers import Horizontal, Vertical\nfrom textual.reactive import reactive\nfrom textual.widgets import Label, Static\n\nif TYPE_CHECKING:\n    from textual.app import ComposeResult\n\n\nclass InfoPanel(Static):\n    \"\"\"Right sidebar showing context stats, MCP servers, and modified files.\n\n    Layout (top to bottom):\n    - Context section (token count + percentage bar)\n    - Activated MCP servers list\n    - Modified files list (created/modified/touched)\n    - Footer with project path/branch and CLI version\n\n    Toggle: Ctrl+M\n    Auto-hide: terminals < 80 columns\n    \"\"\"\n\n    DEFAULT_CSS = \"\"\"\n    InfoPanel {\n        width: 200;\n        height: 100%;\n        dock: right;\n        background: $surface;\n        border-left: solid $primary;\n        padding: 0 1;\n    }\n\n    InfoPanel .info-section {\n        margin-top: 1;\n    }\n\n    InfoPanel .info-label {\n        color: $text-muted;\n        font-size: 11px;\n        margin-bottom: 4px;\n    }\n\n    InfoPanel .info-context-box {\n        background: $surface-darken-1;\n        padding: 6 8;\n        border-radius: 4;\n    }\n\n    InfoPanel .info-context-stats {\n        display: flex;\n        justify-content: space-between;\n        color: $primary;\n    }\n\n    InfoPanel .info-context-pct {\n        color: $text-muted;\n    }\n\n    InfoPanel .info-progress-bar {\n        height: 3;\n        background: $surface-darken-2;\n        border-radius: 2;\n        margin-top: 4;\n    }\n\n    InfoPanel .info-progress-fill {\n        width: 45%;\n        height: 100%;\n        background: $primary;\n        border-radius: 2;\n    }\n\n    InfoPanel .info-mcp-list {\n        max-height: 120;\n        overflow-y: auto;\n    }\n\n    InfoPanel .info-mcp-item {\n        font-size: 11px;\n        margin-bottom: 2;\n    }\n\n    InfoPanel .info-mcp-connected {\n        color: $success;\n    }\n\n    InfoPanel .info-mcp-disconnected {\n        color: $text-muted;\n        opacity: 0.7;\n    }\n\n    InfoPanel .info-files-list {\n        max-height: 150;\n        overflow-y: auto;\n    }\n\n    InfoPanel .info-file-created {\n        color: $success;\n        font-size: 11px;\n    }\n\n    InfoPanel .info-file-modified {\n        color: $warning;\n        font-size: 11px;\n    }\n\n    InfoPanel .info-file-touched {\n        color: $text-muted;\n        font-size: 11px;\n    }\n\n    InfoPanel .info-footer {\n        border-top: solid $primary-darken-2;\n        padding-top: 6;\n        margin-top: auto;\n    }\n\n    InfoPanel .info-project {\n        color: $text-muted;\n        font-size: 10px;\n        word-break: break-all;\n    }\n\n    InfoPanel .info-version {\n        color: $text-muted;\n        font-size: 10px;\n        margin-top: 2;\n    }\n    \"\"\"\n\n    tokens: reactive[int] = reactive(0, init=False)\n    context_limit: reactive[int] = reactive(0, init=False)\n    approximate: reactive[bool] = reactive(False, init=False)\n\n    def __init__(\n        self,\n        *,\n        tokens: int = 0,\n        context_limit: int = 0,\n        mcp_servers: dict[str, Any] | None = None,\n        modified_files: list[tuple[str, str]] | None = None,\n        project_path: str = \"\",\n        branch: str = \"\",\n        cli_name: str = \"agent-tui\",\n        cli_version: str = \"\",\n        **kwargs: Any,\n    ) -> None:\n        \"\"\"Initialize InfoPanel.\n\n        Args:\n            tokens: Current token count\n            context_limit: Context window limit (for percentage)\n            mcp_servers: Dict of server_name -> {connected, tools}\n            modified_files: List of (filepath, change_type) tuples\n            project_path: Current project path\n            branch: Git branch name\n            cli_name: CLI application name\n            cli_version: CLI application version\n        \"\"\"\n        super().__init__(**kwargs)\n        self._tokens = tokens\n        self._context_limit = context_limit\n        self._mcp_servers = mcp_servers or {}\n        self._modified_files = modified_files or []\n        self._project_path = project_path\n        self._branch = branch\n        self._cli_name = cli_name\n        self._cli_version = cli_version\n\n    def compose(self) -> ComposeResult:\n        \"\"\"Compose the info panel layout.\"\"\"\n        yield Horizontal(\n            Label(\"Info\", classes=\"info-title\"),\n            id=\"info-toggle-hint\",\n        )\n\n        with Vertical(id=\"info-content\", classes=\"info-sections\"):\n            yield self._build_context_section()\n            yield self._build_mcp_section()\n            yield self._build_files_section()\n\n        yield self._build_footer()\n\n    def _build_context_section(self) -> Vertical:\n        \"\"\"Build context section with token stats.\"\"\"\n        section = Vertical(classes=\"info-section\")\n        section.append(Label(\"Context\", classes=\"info-label\"))\n\n        box = Vertical(classes=\"info-context-box\")\n        stats = Horizontal(classes=\"info-context-stats\")\n        stats.append(Label(\"0\", id=\"info-token-count\", classes=\"info-context-value\"))\n        stats.append(Label(\"0%\", id=\"info-token-pct\", classes=\"info-context-pct\"))\n        box.append(stats)\n\n        bar = Horizontal(classes=\"info-progress-bar\")\n        bar.append(Static(\"\", id=\"info-progress-fill\", classes=\"info-progress-fill\"))\n        box.append(bar)\n        section.append(box)\n        return section\n\n    def _build_mcp_section(self) -> Vertical:\n        \"\"\"Build MCP servers section.\"\"\"\n        section = Vertical(classes=\"info-section\")\n        section.append(Label(\"Activated MCP\", classes=\"info-label\"))\n        section.append(Vertical(id=\"info-mcp-list\", classes=\"info-mcp-list\"))\n        return section\n\n    def _build_files_section(self) -> Vertical:\n        \"\"\"Build modified files section.\"\"\"\n        section = Vertical(classes=\"info-section\", id=\"info-files-section\")\n        section.append(Label(\"Modified Files\", classes=\"info-label\"))\n        section.append(Vertical(id=\"info-files-list\", classes=\"info-files-list\"))\n        return section\n\n    def _build_footer(self) -> Vertical:\n        \"\"\"Build footer with project and version info.\"\"\"\n        footer = Vertical(classes=\"info-footer\")\n        footer.append(Label(\"\", id=\"info-project\", classes=\"info-project\"))\n        footer.append(Label(\"\", id=\"info-version\", classes=\"info-version\"))\n        return footer\n\n    def on_mount(self) -> None:\n        \"\"\"Initialize panel content on mount.\"\"\"\n        self._update_context_display()\n        self._update_mcp_display()\n        self._update_files_display()\n        self._update_footer_display()\n\n    def _update_context_display(self) -> None:\n        \"\"\"Update context section with current token info.\"\"\"\n        try:\n            count_label = self.query_one(\"#info-token-count\", Label)\n            pct_label = self.query_one(\"#info-token-pct\", Label)\n            fill = self.query_one(\"#info-progress-fill\", Static)\n\n            if self._tokens > 0:\n                suffix = \"+\" if self.approximate else \"\"\n                if self._tokens >= 1000:\n                    formatted = f\"{self._tokens / 1000:.1f}K{suffix}\"\n                else:\n                    formatted = f\"{self._tokens}{suffix}\"\n                count_label.update(formatted)\n\n                if self._context_limit > 0:\n                    pct = int(self._tokens * 100 / self._context_limit)\n                    pct_label.update(f\"{pct}%\")\n                    fill.update(\"\")\n                    fill.styles.width = f\"{min(pct, 100)}%\"\n                else:\n                    pct_label.update(\"\")\n                    fill.update(\"\")\n            else:\n                count_label.update(\"0\")\n                pct_label.update(\"\")\n                fill.update(\"\")\n        except Exception:\n            pass\n\n    def _update_mcp_display(self) -> None:\n        \"\"\"Update MCP servers list.\"\"\"\n        try:\n            mcp_list = self.query_one(\"#info-mcp-list\", Vertical)\n            mcp_list.remove_children()\n\n            if not self._mcp_servers:\n                mcp_list.append(Label(\"No MCP servers\", classes=\"info-muted\"))\n                return\n\n            for server_name, server_info in self._mcp_servers.items():\n                is_connected = server_info.get(\"connected\", False)\n                indicator = \"●\" if is_connected else \"○\"\n                item_class = \"info-mcp-connected\" if is_connected else \"info-mcp-disconnected\"\n                mcp_list.append(\n                    Label(\n                        f\"{indicator} {server_name}\",\n                        classes=f\"info-mcp-item {item_class}\",\n                    )\n                )\n        except Exception:\n            pass\n\n    def _update_files_display(self) -> None:\n        \"\"\"Update modified files list.\"\"\"\n        try:\n            files_list = self.query_one(\"#info-files-list\", Vertical)\n            files_list.remove_children()\n\n            if not self._modified_files:\n                files_list.append(Label(\"No files modified\", classes=\"info-muted\"))\n                return\n\n            for filepath, change_type in self._modified_files:\n                if change_type == \"created\":\n                    files_list.append(\n                        Label(f\"+ {filepath}\", classes=\"info-file-created\")\n                    )\n                elif change_type == \"modified\":\n                    files_list.append(\n                        Label(f\"~ {filepath}\", classes=\"info-file-modified\")\n                    )\n                else:\n                    files_list.append(\n                        Label(f\"• {filepath}\", classes=\"info-file-touched\")\n                    )\n        except Exception:\n            pass\n\n    def _update_footer_display(self) -> None:\n        \"\"\"Update footer with project and version info.\"\"\"\n        try:\n            project_label = self.query_one(\"#info-project\", Label)\n            version_label = self.query_one(\"#info-version\", Label)\n\n            if self._branch:\n                project_label.update(f\"~/{self._project_path}:{self._branch}\")\n            else:\n                project_label.update(f\"~/{self._project_path}\")\n\n            if self._cli_version:\n                version_label.update(f\"{self._cli_name} v{self._cli_version}\")\n            else:\n                version_label.update(self._cli_name)\n        except Exception:\n            pass\n\n    def set_tokens(self, count: int, *, approximate: bool = False, context_limit: int = 0) -> None:\n        \"\"\"Update token display.\n\n        Args:\n            count: Current context token count\n            approximate: Append \"+\" to indicate stale count\n            context_limit: Context window limit for percentage\n        \"\"\"\n        self._tokens = count\n        self._context_limit = context_limit\n        self.approximate = approximate\n        self._update_context_display()\n\n    def set_mcp_servers(self, servers: dict[str, Any]) -> None:\n        \"\"\"Update MCP servers list.\n\n        Args:\n            servers: Dict of server_name -> {connected, tools}\n        \"\"\"\n        self._mcp_servers = servers\n        self._update_mcp_display()\n\n    def add_modified_file(self, filepath: str, change_type: str) -> None:\n        \"\"\"Add a modified file to the list.\n\n        Args:\n            filepath: Path to the file\n            change_type: One of \"created\", \"modified\", \"touched\"\n        \"\"\"\n        self._modified_files.append((filepath, change_type))\n        self._update_files_display()\n\n    def set_project_info(self, path: str, branch: str, cli_name: str, cli_version: str) -> None:\n        \"\"\"Update project and version info.\n\n        Args:\n            path: Project path (home-relative)\n            branch: Git branch name\n            cli_name: CLI application name\n            cli_version: CLI version string\n        \"\"\"\n        self._project_path = path\n        self._branch = branch\n        self._cli_name = cli_name\n        self._cli_version = cli_version\n        self._update_footer_display()\n```\n\n- [ ] **Step 2: Add CSS to app.tcss**\n\nAdd after line 370:\n```css\n/* Info Panel styling */\nInfoPanel {\n    width: 200;\n    height: 100%;\n    dock: right;\n    background: $surface;\n    border-left: solid $primary;\n    padding: 0 1;\n}\n\nInfoPanel .info-title {\n    text-style: bold;\n    height: 1;\n    padding: 0 1;\n    border-bottom: solid $primary-darken-2;\n}\n\nInfoPanel .info-toggle-hint {\n    color: $text-muted;\n    font-size: 10px;\n    text-align: center;\n}